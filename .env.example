# ─── 灵枢 (LingShu Agent) 配置文件 ───
# 复制此文件为 .env 并填入你的配置：
#   cp .env.example .env
#
# 所有配置项也可通过环境变量设置（优先级高于 .env）。

# ─── LLM 后端（至少配置一个） ───

# 1. DeepSeek API（推荐，云端）
HARNESS_DEEPSEEK_API=https://api.deepseek.com/v1/chat/completions
HARNESS_CLOUD_KEY=sk-your-deepseek-api-key-here

# 2. 本地 Llama.cpp（需要本地运行 llama.cpp 服务器）
# HARNESS_LLAMA_API=http://127.0.0.1:8081/v1/chat/completions

# 3. Ollama（WSL 或本地）
# HARNESS_OLLAMA_API=http://127.0.0.1:11434/api/generate

# ─── 服务端口 ───
HARNESS_API_HOST=127.0.0.1
HARNESS_API_PORT=8788

# ─── 可选：关闭 API 认证（不推荐，仅局域网调试用） ───
# HARNESS_DISABLE_AUTH=1

# ─── 可选：关闭速率限制 ───
# HARNESS_DISABLE_RATE_LIMIT=1

# ─── 并发控制 ───
# HARNESS_MAX_CONCURRENT_AGENTS=5
# HARNESS_MAX_WORKERS=3
# HARNESS_MAX_TOKENS=100000
