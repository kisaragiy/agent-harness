/* pages/chat/chat.wxss */
page {
  background: #f5f6f8;
}
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f6f8;
}

.mode-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 16px;
  background: white;
  border-bottom: 1px solid #eee;
}
.mode-label {
  font-size: 13px;
  color: #2563eb;
  font-weight: 500;
}
.clear-btn {
  font-size: 13px;
  color: #999;
  padding: 4px 8px;
}

.messages {
  flex: 1;
  overflow-y: auto;
  padding: 16px;
  padding-bottom: 8px;
}

.message-row {
  display: flex;
  margin-bottom: 16px;
  align-items: flex-start;
}

.user-row {
  flex-direction: row-reverse;
}

.avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  color: white;
  flex-shrink: 0;
}

.user-avatar { background: #2563eb; }
.bot-avatar { background: #10b981; }

.bubble {
  max-width: 70%;
  padding: 10px 14px;
  border-radius: 12px;
  font-size: 15px;
  line-height: 1.5;
  word-break: break-word;
}

.user-bubble {
  background: #2563eb;
  color: white;
  margin-right: 10px;
  border-bottom-right-radius: 4px;
}

.bot-bubble {
  background: white;
  color: #333;
  margin-left: 10px;
  border-bottom-left-radius: 4px;
  box-shadow: 0 1px 2px rgba(0,0,0,0.06);
}

/* Loading 动画 */
.loading-indicator {
  display: flex;
  margin-bottom: 16px;
  align-items: center;
}
.loading-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  color: white;
  flex-shrink: 0;
  background: #10b981;
}
.loading-bubble {
  background: white;
  border-radius: 12px;
  padding: 14px 18px;
  margin-left: 10px;
  border-bottom-left-radius: 4px;
  box-shadow: 0 1px 2px rgba(0,0,0,0.06);
}
.dot-pulse {
  display: flex;
  align-items: center;
}
.dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #999;
  margin-right: 4px;
  animation: pulse 1.4s infinite ease-in-out;
}
.dot1 { animation-delay: 0s; }
.dot2 { animation-delay: 0.2s; }
.dot3 { animation-delay: 0.4s; }
@keyframes pulse {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* 快捷回复 */
.quick-replies {
  margin-bottom: 12px;
}
.qr-title {
  font-size: 12px;
  color: #999;
  margin-bottom: 8px;
}
.qr-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.qr-item {
  background: white;
  border: 1px solid #2563eb;
  border-radius: 16px;
  padding: 6px 14px;
  font-size: 13px;
  color: #2563eb;
}
.qr-item:active {
  background: #2563eb;
  color: white;
}

/* 输入区 */
.input-area {
  display: flex;
  padding: 12px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom, 0px));
  background: white;
  border-top: 1px solid #eee;
  align-items: center;
}

.input-wrapper {
  flex: 1;
  background: #f0f0f0;
  border-radius: 20px;
  padding: 0 16px;
  margin-right: 10px;
}

.text-input {
  height: 40px;
  font-size: 15px;
}

.send-btn {
  width: 56px;
  height: 36px;
  background: #2563eb;
  border-radius: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 14px;
}

.send-btn.disabled {
  background: #ccc;
}
