<!-- pages/home/home.wxml -->
<view class="container">
  <view class="header">
    <text class="title">灵枢</text>
    <text class="subtitle">AI 应用开发助手</text>
  </view>

  <view class="status-row" bindtap="checkConnection">
    <view class="status-indicator {{connected ? 'online' : 'offline'}}">
      <view class="status-dot"></view>
      <text class="status-text">{{connected ? '服务运行中' : '服务未连接'}}</text>
    </view>
    <text class="status-hint">{{checking ? '检测中...' : (connected ? '点击刷新' : '去设置')}}</text>
  </view>

  <view class="scenario-list">
    <view class="scenario-card" bindtap="goChat">
      <text class="scenario-icon">💬</text>
      <view class="scenario-info">
        <text class="scenario-name">AI 对话</text>
        <text class="scenario-desc">智能问答 · 信息检索 · 日常对话</text>
      </view>
      <text class="arrow">›</text>
    </view>

    <view class="scenario-card" bindtap="goResearch">
      <text class="scenario-icon">📊</text>
      <view class="scenario-info">
        <text class="scenario-name">调研助手</text>
        <text class="scenario-desc">关键词搜索 → 分析 → 生成正式报告</text>
      </view>
      <text class="arrow">›</text>
    </view>

    <view class="scenario-card" bindtap="goCS">
      <text class="scenario-icon">🎧</text>
      <view class="scenario-info">
        <text class="scenario-name">智能客服</text>
        <text class="scenario-desc">售前咨询 · 订单查询 · 售后处理</text>
      </view>
      <text class="arrow">›</text>
    </view>

    <view class="scenario-card" bindtap="goReports">
      <text class="scenario-icon">📄</text>
      <view class="scenario-info">
        <text class="scenario-name">调研报告</text>
        <text class="scenario-desc">查看已生成的调研报告</text>
      </view>
      <text class="arrow">›</text>
    </view>

    <view class="scenario-card" bindtap="goAbout">
      <text class="scenario-icon">ℹ️</text>
      <view class="scenario-info">
        <text class="scenario-name">关于</text>
        <text class="scenario-desc">版本信息 · 开发团队 · 联系方式</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>
</view>
