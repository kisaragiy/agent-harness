<!-- pages/settings/settings.wxml -->
<view class="container">
  <view class="section">
    <view class="section-title">API 配置</view>

    <view class="field">
      <text class="label">服务器地址</text>
      <input class="input" placeholder="http://127.0.0.1:8765"
        value="{{apiBase}}" bindinput="onApiBaseInput"/>
      <text class="field-hint">例如：http://192.168.1.100:8765</text>
    </view>

    <view class="field">
      <text class="label">API Token</text>
      <input class="input" placeholder="输入 API Key"
        value="{{apiToken}}" bindinput="onApiTokenInput"/>
    </view>

    <button class="save-btn" bindtap="saveSettings">保存配置</button>
    <button class="test-btn" bindtap="testConnection">测试连接</button>
  </view>

  <view class="section tips-section">
    <view class="section-title">说明</view>
    <text class="tip-text">• 健康检查路径：/health</text>
    <text class="tip-text">• API 路径前缀：/v1/（例如 /v1/chat/completions）</text>
    <text class="tip-text">• Token 可在服务端 api_token.txt 中查看</text>
    <text class="tip-text">• 修改配置后请保存并测试连接</text>
  </view>
</view>
