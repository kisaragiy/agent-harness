<!-- pages/settings/settings.wxml -->
<view class="container">
  <view class="section">
    <view class="section-title">服务器配置</view>

    <view class="field">
      <text class="label">服务器地址</text>
      <input class="input" placeholder="http://192.168.31.182:8788"
        value="{{apiBase}}" bindinput="onApiBaseInput"/>
      <text class="field-hint">真机调试：填电脑局域网 IP + :8788</text>
    </view>

    <button class="save-btn" bindtap="saveSettings">保存配置</button>
    <button class="test-btn" bindtap="testConnection">测试连接</button>
  </view>

  <view class="section">
    <view class="section-title">当前用户</view>

    <view class="field">
      <text class="label">用户 ID</text>
      <text class="value">{{userId}}</text>
    </view>
    <view class="field">
      <text class="label">用户名</text>
      <text class="value">{{username}}</text>
    </view>
    <view class="field">
      <text class="label">登录方式</text>
      <text class="value">{{loginTime}}</text>
    </view>

    <button class="relogin-btn" bindtap="reLogin">🔄 重新登录</button>
  </view>

  <view class="section tips-section">
    <view class="section-title">说明</view>
    <text class="tip-text">• 小程序使用自动登录，无需手动输入 API Token</text>
    <text class="tip-text">• 首次打开会自动注册设备并登录</text>
    <text class="tip-text">• 系统会自动为每个设备分配独立用户 ID</text>
    <text class="tip-text">• 各设备之间的数据相互隔离</text>
  </view>
</view>
