<!-- pages/mine/mine.wxml -->
<view class="container">
  <view class="profile">
    <view class="avatar">
      <text>灵</text>
    </view>
    <view class="profile-info">
      <text class="profile-name">灵枢用户</text>
      <text class="profile-desc">AI 应用开发助手</text>
    </view>
  </view>

  <view class="connection-status">
    <view class="status-dot {{connected ? 'online' : 'offline'}}"></view>
    <text class="status-text">{{connected ? 'API 已连接' : 'API 未连接'}}</text>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goSettings">
      <text class="menu-icon">⚙️</text>
      <text class="menu-label">设置</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goAbout">
      <text class="menu-icon">📖</text>
      <text class="menu-label">关于</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goContact">
      <text class="menu-icon">📞</text>
      <text class="menu-label">联系开发者</text>
      <text class="arrow">›</text>
    </view>
  </view>
</view>
